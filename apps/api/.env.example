# Database
# Use the SESSION pooler URL (port 5432) from Supabase → Project Settings → Database → Session tab
# Do NOT use the transaction pooler (port 6543) — asyncpg does not support it.
# URL-encode special characters in the password (@ -> %40, etc.)
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Redis
# Local: redis://localhost:6379
# Production (Upstash): use the rediss:// TLS URL from the Upstash console
REDIS_URL=redis://localhost:6379

# Supabase
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# CORS — comma-separated list of allowed frontend origins
# Local dev default is http://localhost:3000; in production add your Vercel URL,
# e.g. CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000

# Public frontend URL (used in notification email links)
FRONTEND_URL=http://localhost:3000

# GitHub App
GITHUB_APP_ID=123456
# Local: point to a .pem file on disk
GITHUB_APP_PRIVATE_KEY_PATH=./github-app.pem
# Production (Render/Vercel have no file path): paste the full PEM contents here
# instead of the path. Either one works — the code prefers the inline key.
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# Claude AI
ANTHROPIC_API_KEY=sk-ant-...

# JWT (for WebSocket auth)
JWT_SECRET=your_random_32_char_secret

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_ADDRESS=onboarding@resend.dev
